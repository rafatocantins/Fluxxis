{
  "name": "@fluxxis/core",
  "version": "0.2.0",
  "description": "FLUXXIS Adaptive Structural Interface Engine — Framework-agnostic core",
  "author": "FLUXXIS Research Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rafatocantins/fluxxis.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/rafatocantins/fluxxis/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/rafatocantins/fluxxis/issues"
  },
  "keywords": [
    "adaptive-ui",
    "intent-driven",
    "behavioral-interface",
    "fluxxis",
    "adaptive-components",
    "typescript",
    "framework-agnostic"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./signals": {
      "types": "./dist/signals/index.d.ts",
      "import": "./dist/signals/index.js",
      "require": "./dist/signals/index.cjs"
    },
    "./intents": {
      "types": "./dist/intents/index.d.ts",
      "import": "./dist/intents/index.js",
      "require": "./dist/intents/index.cjs"
    },
    "./analytics": {
      "types": "./dist/analytics/index.d.ts",
      "import": "./dist/analytics/index.js",
      "require": "./dist/analytics/index.cjs"
    },
    "./structured-data": {
      "types": "./dist/structured-data/index.d.ts",
      "import": "./dist/structured-data/index.js",
      "require": "./dist/structured-data/index.cjs"
    },
    "./licensing": {
      "types": "./dist/licensing/index.d.ts",
      "import": "./dist/licensing/index.js",
      "require": "./dist/licensing/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.1.6",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
