{
  "name": "@fluxxis/ui",
  "version": "0.2.0",
  "description": "FLUXXIS Design Tokens v2.0 — CSS custom properties and theme primitives",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tokens": "./dist/tokens.css"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "fluxxis",
    "design-tokens",
    "css-custom-properties",
    "theme",
    "adaptive-ui",
    "dark-mode"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rafatocantins/fluxxis.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.1.6"
  }
}
