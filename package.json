{
  "name": "fluxxis",
  "version": "0.2.0",
  "description": "FLUXXIS Monorepo — Adaptive Structural Interface Engine",
  "author": "FLUXXIS Research Team",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/rafatocantins/fluxxis.git"
  },
  "homepage": "https://github.com/rafatocantins/fluxxis#readme",
  "bugs": {
