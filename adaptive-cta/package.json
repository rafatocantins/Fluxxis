{
  "name": "@fluxxis/adaptive-cta",
  "version": "0.1.0",
  "description": "Adaptive CTA Engine — Intent-driven call-to-action buttons for e-commerce. SaaS €29/mês. Shopify + WooCommerce.",
  "author": "FLUXXIS Research Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rafatocantins/Fluxxis.git",
    "directory": "adaptive-cta"
  },
  "homepage": "https://fluxxis.dev/adaptive-cta",
  "bugs": {
    "url": "https://github.com/rafatocantins/Fluxxis/issues"
  },
  "keywords": [
    "adaptive-ui",
    "intent-driven",
    "cta",
    "call-to-action",
    "e-commerce",
    "shopify",
    "woocommerce",
    "fluxxis",
    "react",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "unpkg": "./dist/index.umd.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./intent-resolver": {
      "types": "./dist/intent-resolver.d.ts",
      "import": "./dist/intent-resolver.js",
      "require": "./dist/intent-resolver.cjs"
    },
    "./tracking": {
      "types": "./dist/tracking.d.ts",
      "import": "./dist/tracking.js",
      "require": "./dist/tracking.cjs"
    },
    "./ds-adapter": {
      "types": "./dist/ds-adapter.d.ts",
      "import": "./dist/ds-adapter.js",
      "require": "./dist/ds-adapter.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "shopify",
    "woocommerce",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^24.1.3",
    "tsup": "^8.0.0",
    "typescript": "^5.1.6",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
